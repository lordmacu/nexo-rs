# MiniMax (primary LLM)
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_GROUP_ID=your_minimax_group_id_here

# OpenAI (optional fallback)
OPENAI_API_KEY=

# Anthropic (optional)
ANTHROPIC_API_KEY=

# Telegram
TELEGRAM_BOT_TOKEN=

# WhatsApp — path to credentials file managed by whatsapp-rs
WA_CREDENTIALS_FILE=/data/sessions/wa_credentials.json

# NATS
NATS_URL=nats://localhost:4222
NATS_NKEY_FILE=/run/secrets/nats.nkey

# Redis (optional — only if memory backend = redis)
REDIS_URL=redis://localhost:6379

# Logging
RUST_LOG=info
