# MiniMax (primary LLM)
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_GROUP_ID=your_minimax_group_id_here

# OpenAI (optional fallback)
OPENAI_API_KEY=

# Anthropic (optional)
ANTHROPIC_API_KEY=

# Google Gemini — two independent paths
#   1. Official API (Google AI Studio): aistudio.google.com/apikey
GEMINI_API_KEY=
#   2. Web-UI automation (gemini.google.com via Chrome, free tier).
#      Browser logs in with these creds; cookies persist in the profile.
#      Secondary pair is optional — lets the automation rotate accounts
#      when the primary hits daily rate limits.
GEMINI_EMAIL=
GEMINI_PASSWORD=
GEMINI_EMAIL2=
GEMINI_PASSWORD2=

# Telegram
TELEGRAM_BOT_TOKEN=

# WhatsApp — path to credentials file managed by whatsapp-rs
WA_CREDENTIALS_FILE=/data/sessions/wa_credentials.json

# NATS
NATS_URL=nats://localhost:4222
NATS_NKEY_FILE=/run/secrets/nats.nkey

# Redis (optional — only if memory backend = redis)
REDIS_URL=redis://localhost:6379

# Logging
RUST_LOG=info
