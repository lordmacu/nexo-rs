{
    "name": "nexo/template-plugin-php",
    "description": "Skeleton out-of-tree subprocess plugin for nexo (PHP). Phase 31.5.c.",
    "type": "project",
    "license": "MIT OR Apache-2.0",
    "authors": [
        {
            "name": "Cristian Garcia",
            "email": "informacion@cristiangarcia.co"
        }
    ],
    "require": {
        "php": "^8.1",
        "nexo/plugin-sdk": "^0.1.0"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../sdk-php",
            "options": {
                "symlink": false
            }
        }
    ],
    "autoload": {
        "psr-4": {
            "TemplatePluginPhp\\": "src/"
        }
    },
    "config": {
        "sort-packages": true,
        "preferred-install": "dist"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
