{"id":"smoke-en-001","input":{"channel":"whatsapp","sender":"+1234567890","text":"Hi"},"expectations":[{"kind":"no_error","weight":1.0},{"kind":"regex_response","pattern":"(?i)(hi|hello|hey)","weight":1.0},{"kind":"response_lang","value":"en","weight":0.5},{"kind":"response_max_tokens","max_tokens":80,"weight":0.5}],"tags":["greeting"],"notes":"Short greeting, expect short greeting back."}
{"id":"smoke-en-002","input":{"channel":"whatsapp","sender":"+1234567890","text":"What time is it?"},"expectations":[{"kind":"no_error","weight":1.0},{"kind":"tool_called","name":"current_time","weight":1.0}],"tags":["tool-routing","time"],"notes":"Must call the tool, not hallucinate the time."}
{"id":"smoke-en-003","input":{"channel":"whatsapp","sender":"+1234567890","text":"What's the weather in Madrid?"},"expectations":[{"kind":"no_error","weight":1.0},{"kind":"tool_called","name":"weather","weight":1.0}],"tags":["tool-routing","weather"],"notes":"External-data question must route to a tool."}
{"id":"smoke-en-004","input":{"channel":"whatsapp","sender":"+1234567890","text":"Send this message to mom: 'be back at 6pm'"},"expectations":[{"kind":"no_error","weight":1.0},{"kind":"tool_called","name":"send_whatsapp","weight":1.0}],"tags":["tool-routing","outbound"],"notes":"Should infer the contact + payload + outbound tool."}
{"id":"smoke-en-005","input":{"channel":"whatsapp","sender":"+1234567890","text":"What is 23 * 47?"},"expectations":[{"kind":"no_error","weight":1.0},{"kind":"regex_response","pattern":"1081","weight":1.0}],"tags":["arithmetic"],"notes":"Cheap math doesn't need a tool but the result must be correct."}
{"id":"smoke-en-006","input":{"channel":"whatsapp","sender":"+1234567890","text":"Tell me a joke"},"expectations":[{"kind":"no_error","weight":1.0},{"kind":"response_max_tokens","max_tokens":120,"weight":0.5}],"tags":["chitchat"],"notes":"Open-ended; just verify no error and a bounded response."}
{"id":"smoke-en-007","input":{"channel":"whatsapp","sender":"+1234567890","text":"Remind me to call the dentist tomorrow at 10am"},"expectations":[{"kind":"no_error","weight":1.0},{"kind":"tool_called","name":"reminder","weight":1.0}],"tags":["tool-routing","reminder"],"notes":"Future-tense action must trigger the reminder tool."}
{"id":"smoke-en-008","input":{"channel":"whatsapp","sender":"+1234567890","text":"What did I tell you yesterday about my flight?"},"expectations":[{"kind":"no_error","weight":1.0},{"kind":"tool_called","name":"memory_recall","weight":1.0}],"tags":["memory"],"notes":"Past-context question must hit memory."}
{"id":"smoke-en-009","input":{"channel":"whatsapp","sender":"+1234567890","text":"Search the web for the latest Rust release"},"expectations":[{"kind":"no_error","weight":1.0},{"kind":"tool_called","name":"web_search","weight":1.0}],"tags":["tool-routing","web"],"notes":"Explicit web request must route to web_search."}
{"id":"smoke-en-010","input":{"channel":"whatsapp","sender":"+1234567890","text":"Open https://example.com and tell me what's there"},"expectations":[{"kind":"no_error","weight":1.0},{"kind":"tool_called","name":"link_understanding","weight":1.0}],"tags":["tool-routing","links"],"notes":"User-shared URL must trigger link understanding."}
{"id":"smoke-en-011","input":{"channel":"whatsapp","sender":"+1234567890","text":"Thanks"},"expectations":[{"kind":"no_error","weight":1.0},{"kind":"response_max_tokens","max_tokens":40,"weight":1.0}],"tags":["chitchat"],"notes":"Acknowledgements should be terse."}
